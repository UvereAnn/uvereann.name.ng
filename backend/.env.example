# =============================================================
# ENVIRONMENT VARIABLES — copy this file to .env and fill in
# =============================================================
# WHY THIS FILE EXISTS:
# .env contains real values and is NEVER committed to git
# .env.example shows what variables exist (committed to git)
# Anyone cloning the repo knows what variables they need
# =============================================================

# Port the server listens on
# WHY: Different environments may use different ports
PORT=3000

# Environment name — affects logging, error detail, CORS
# OPTIONS: development | production | test
NODE_ENV=development

# Which frontend URL is allowed to call this backend
# WHY CORS: Browsers block cross-origin requests for security
# In development: your Vite dev server
# In production: your real domain
ALLOWED_ORIGIN=http://localhost:5173

# Where to store the SQLite database file
# WHY: Lets us put it in different places per environment
DB_PATH=./database.db

# =============================================================
# EMAIL NOTIFICATIONS (Resend)
# =============================================================
# Get your free API key at: https://resend.com
# Free tier: 3,000 emails/month — no credit card needed
#
# HOW TO GET YOUR KEY:
# 1. Sign up at resend.com
# 2. Go to API Keys → Create API Key
# 3. Name it: portfolio-contact-form
# 4. Permission: Sending access
# 5. Copy the key and paste below
#
# Leave as the placeholder value during local development —
# the code detects this and skips sending (no errors).
RESEND_API_KEY=your_resend_api_key_here

# The email address where YOU want to receive notifications
# When someone fills the contact form, an email goes here
NOTIFY_EMAIL=your@email.com

# =============================================================
# ADMIN PANEL
# =============================================================
# Protects the messages viewer at:
# /api/admin/messages?secret=YOUR_ADMIN_SECRET
#
# HOW TO GENERATE A STRONG SECRET:
# Run this command in your terminal and copy the output:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# IMPORTANT:
# - Use a long random string (the command above generates one)
# - Never share this value
# - Never commit your actual .env file
ADMIN_SECRET=your_long_random_secret_here